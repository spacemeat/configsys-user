{
    // configsys-user — spacemeat's personal configsys layer (profiles, components, dotfiles).
    // Designated `primary: true` in the machine's top ~/.config/configsys/configsys.hu, so its
    // machine settings (configs / scope / pins) apply as this account's portable defaults, with
    // the top config overriding per-machine. Ships no code — just data + dotfiles.
    name: configsys-user
    version: 0.0.3
    requires-abi: 1

    data: [ configsys.hu ]

    // Transitive plugins this personal layer brings along, so a fresh machine bootstraps from a
    // single primary declaration and `configsys plugin sync` pulls the rest.
    plugins: [
        { source: "github:spacemeat/configsys-blender"  ref: v0.1.2 }
    ]
}
